# .env.example - کپی این فایل به .env و مقادیر را پر کنید
# SECURITY: All values marked REQUIRED must be set in production

# Flask
FLASK_ENV=production
SECRET_KEY=REQUIRED_GENERATE_WITH: python -c "import secrets; print(secrets.token_hex(32))"

# Database
DATABASE_URL=sqlite:///damdari.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:pass@localhost/damdari

# Admin Account
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REQUIRED_SET_STRONG_PASSWORD
ADMIN_NAME=مدیر سیستم

# Telegram/SMS
TELEGRAM_API_KEY=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
SMS_API_KEY=your-sms-api-key
SMS_SENDER_NUMBER=your-sender-number

# IoT Devices API Token
IOT_API_TOKEN=REQUIRED_GENERATE_WITH: python -c "import secrets; print(secrets.token_urlsafe(32))"

# AI/ML APIs
OPENROUTER_API_KEY=your-openrouter-api-key
DEEPSEEK_MODEL=deepseek/deepseek-chat

# System Settings
VAT_RATE=10
CURRENCY_UNIT=تومان
MARKET_PRICE=0
MATURITY_DAYS=180
BIRTH_WEIGHT=3.5
DAILY_FEED_EST=15000
